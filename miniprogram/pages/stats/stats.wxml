<!--pages/stats/stats.wxml-->
<view class="container">
  <!-- 头部 -->
  <view class="header">
    <view class="header-title">统计</view>
    <view class="header-subtitle">数据概览与分析</view>
  </view>

  <view class="tabs">
    <view class="tab {{currentTab === 'today' ? 'active' : ''}}" bindtap="switchTab" data-tab="today">今日</view>
    <view class="tab {{currentTab === 'week' ? 'active' : ''}}" bindtap="switchTab" data-tab="week">本周</view>
    <view class="tab {{currentTab === 'month' ? 'active' : ''}}" bindtap="switchTab" data-tab="month">本月</view>
  </view>

  <scroll-view class="content" scroll-y>
    <!-- 今日 -->
    <view class="tab-content" wx:if="{{currentTab === 'today'}}">
      <view class="chart-section">
        <view class="chart-title">车辆状态</view>
        <view class="stats-grid">
          <view class="stat-card">
            <view class="stat-value" style="color: #00b894;">{{todayStats.rentingCars}}</view>
            <view class="stat-label">租聘中</view>
          </view>
          <view class="stat-card">
            <view class="stat-value" style="color: #74b9ff;">{{todayStats.idleCars}}</view>
            <view class="stat-label">空闲</view>
          </view>
          <view class="stat-card">
            <view class="stat-value" style="color: #e17055;">{{todayStats.pendingSettle}}</view>
            <view class="stat-label">待结算</view>
          </view>
        </view>
      </view>

      <view class="chart-section">
        <view class="chart-title">今日概况</view>
        <view class="stats-grid">
          <view class="stat-card">
            <view class="stat-value" style="color: #00b894;">+{{todayStats.newCars}}</view>
            <view class="stat-label">新增车辆</view>
          </view>
          <view class="stat-card">
            <view class="stat-value" style="color: #636e72;">{{todayStats.totalCars}}</view>
            <view class="stat-label">车辆总数</view>
          </view>
        </view>
      </view>
    </view>

    <!-- 本周 -->
    <view class="tab-content" wx:if="{{currentTab === 'week'}}">
      <view class="chart-section">
        <view class="chart-title">本周订单</view>
        <view class="stat-card" style="text-align: left;">
          <view class="stat-value" style="font-size: 72rpx;">{{weekStats.totalOrders}}</view>
          <view class="stat-label">本周累计订单</view>
        </view>
      </view>

      <view class="chart-section">
        <view class="chart-title">近7天订单趋势</view>
        <view class="line-chart">
          <canvas type="2d" id="weekChart" class="chart-canvas" bindtap="tapWeekChart"></canvas>
        </view>
        <view class="chart-tooltip" wx:if="{{weekTooltip.show}}" style="left: {{weekTooltip.x}}px; top: {{weekTooltip.y}}px;">
          <text class="tooltip-label">{{weekTooltip.label}}</text>
          <text class="tooltip-value">{{weekTooltip.value}}单</text>
        </view>
      </view>

      <view class="chart-section">
        <view class="chart-title">本周概况</view>
        <view class="stats-grid">
          <view class="stat-card">
            <view class="stat-value" style="color: #00b894;">+{{weekStats.newCars}}</view>
            <view class="stat-label">新增车辆</view>
          </view>
        </view>
      </view>
    </view>

    <!-- 本月 -->
    <view class="tab-content" wx:if="{{currentTab === 'month'}}">
      <view class="chart-section">
        <view class="chart-title">本月订单</view>
        <view class="stat-card" style="text-align: left;">
          <view class="stat-value" style="font-size: 72rpx;">{{monthStats.totalOrders}}</view>
          <view class="stat-label">本月累计订单</view>
        </view>
      </view>

      <view class="chart-section">
        <view class="chart-title">近30天订单趋势</view>
        <view class="line-chart">
          <canvas type="2d" id="monthChart" class="chart-canvas" bindtap="tapMonthChart"></canvas>
        </view>
        <view class="chart-tooltip" wx:if="{{monthTooltip.show}}" style="left: {{monthTooltip.x}}px; top: {{monthTooltip.y}}px;">
          <text class="tooltip-label">{{monthTooltip.label}}</text>
          <text class="tooltip-value">{{monthTooltip.value}}单</text>
        </view>
      </view>

      <view class="chart-section">
        <view class="chart-title">本月概况</view>
        <view class="stats-grid">
          <view class="stat-card">
            <view class="stat-value" style="color: #00b894;">+{{monthStats.newCars}}</view>
            <view class="stat-label">新增车辆</view>
          </view>
        </view>
      </view>

      <view class="chart-section" wx:if="{{topCars.length > 0}}">
        <view class="chart-title">热门车型 TOP5</view>
        <view class="list-item" wx:for="{{topCars}}" wx:key="index">
          <text class="item-name">{{item.name}}</text>
          <text class="item-count">{{item.count}}次</text>
        </view>
      </view>
    </view>
  </scroll-view>

</view>