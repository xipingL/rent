/* pages/profile/profile.wxss */
.container {
  min-height: 100vh;
  background: #f5f6fa;
}

.header {
  width: 100%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 60rpx 40rpx 120rpx;
  box-sizing: border-box;
}

.user-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 48rpx 40rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.12);
  text-align: center;
}

/* 头像区域 */
.avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 32rpx;
}

.avatar-wrapper {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.3);
}

.avatar-img {
  width: 100%;
  height: 100%;
}

.avatar-placeholder {
  font-size: 80rpx;
  color: #ffffff;
}

.avatar-tip {
  font-size: 22rpx;
  color: #a0aec0;
  margin-top: 12rpx;
}

/* 名字区域 */
.name-section {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.username {
  font-size: 40rpx;
  font-weight: 600;
  color: #2d3436;
}

.edit-btn {
  font-size: 24rpx;
  padding: 8rpx;
}

/* openId 区域 */
.openid-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.openid-label {
  font-size: 22rpx;
  color: #a0aec0;
}

.openid-value {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.openid-text {
  font-size: 24rpx;
  color: #718096;
  font-family: monospace;
}

.copy-btn {
  font-size: 20rpx;
  color: #667eea;
  background: #f0f0ff;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

/* 内容区域 */
.content {
  width: 100%;
  padding: 0 32rpx;
  margin-top: -60rpx;
  box-sizing: border-box;
}

.menu-list {
  width: 100%;
  background: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
}

.menu-item {
  width: 100%;
  padding: 36rpx 32rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-bottom: 1rpx solid #f1f2f6;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-left {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.menu-icon {
  font-size: 40rpx;
}

.menu-text {
  font-size: 30rpx;
  color: #2d3436;
}

.menu-arrow {
  font-size: 32rpx;
  color: #b2bec3;
}

/* 版本信息 */
.version {
  width: 100%;
  text-align: center;
  font-size: 22rpx;
  color: #a0aec0;
  padding: 48rpx 0;
}
