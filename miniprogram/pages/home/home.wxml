<!--pages/home/home.wxml-->
<view class="container">
  <!-- 头部区域 -->
  <view class="header">
    <view class="header-top">
      <view class="header-title">YeaRent</view>
      <view class="header-subtitle">商家电瓶车租聘管理平台</view>
    </view>
    <!-- 统计卡片 -->
    <view class="stats-card">
      <view class="stat-item">
        <view class="stat-number">{{stats.rentingCars}}</view>
        <view class="stat-label">在租车辆</view>
      </view>
      <view class="stat-item">
        <view class="stat-number">{{stats.idleCars}}</view>
        <view class="stat-label">空闲车辆</view>
      </view>
      <view class="stat-item">
        <view class="stat-number">{{todayOrders}}</view>
        <view class="stat-label">今日订单</view>
      </view>
    </view>
  </view>

  <!-- 功能区域 -->
  <view class="content">
    <view class="section-title">核心功能</view>
    <view class="menu-grid">
      <!-- 我的车库 -->
      <view class="menu-card garage-card" bindtap="goToGarage">
        <view class="garage-icon">🏠</view>
        <text class="garage-title">我的车库</text>
        <text class="garage-desc">管理您的全部车辆</text>
      </view>

      <!-- 两个功能卡片 -->
      <view class="func-row">
        <view class="func-card" bindtap="goToRental">
          <view class="func-icon">🚲</view>
          <text class="func-title">租聘</text>
          <text class="func-desc">租聘车辆</text>
        </view>
        <view class="func-card" bindtap="goToSettle">
          <view class="func-icon">↩️</view>
          <text class="func-title">退租</text>
          <text class="func-desc">车辆退还</text>
        </view>
      </view>
    </view>

    <!-- 快捷操作 -->
    <view class="quick-actions">
      <view class="section-title">快捷操作</view>
      <view class="action-list">
        <view class="action-item" bindtap="goToAddVehicle">
          <text class="action-icon">➕</text>
          <text class="action-text">添加车辆</text>
          <text class="action-arrow">›</text>
        </view>
        <view class="action-item" bindtap="goToOrderHistory">
          <text class="action-icon">📜</text>
          <text class="action-text">历史订单</text>
          <text class="action-arrow">›</text>
        </view>
        <view class="action-item" bindtap="goToStats">
          <text class="action-icon">📊</text>
          <text class="action-text">数据统计</text>
          <text class="action-arrow">›</text>
        </view>
      </view>
    </view>
  </view>

</view>