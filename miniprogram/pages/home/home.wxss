/* pages/home/home.wxss */
.container {
  width: 100%;
  min-height: 100vh;
  background: #F5F6F7;
}

/* 头部区域 */
.header {
  width: 100%;
  background: linear-gradient(135deg, #00d4aa 0%, #00b894 100%);
  padding: 100rpx 16rpx 40rpx;
  position: relative;
  box-sizing: border-box;
}

.header-top {
  margin-bottom: 32rpx;
}

.header-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #ffffff;
  margin-bottom: 8rpx;
}

.header-subtitle {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
}

/* 统计卡片 */
.stats-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 5%;
}

.stats-card .stat-item {
  flex: 1;
  text-align: center;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 16rpx;
  padding: 20rpx 0;
  backdrop-filter: blur(10px);
}

.stat-number {
  font-size: 36rpx;
  font-weight: 700;
  color: #ffffff;
  max-width: 100%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.stat-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-top: 6rpx;
}

/* 内容区域 */
.content {
  width: 100%;
  padding: 32rpx 48rpx 120rpx;
  margin-top: 32rpx;
  position: relative;
  z-index: 1;
  box-sizing: border-box;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 24rpx;
  padding: 0 24rpx;
}

/* 菜单网格 */
.menu-grid {
  width: 100%;
  margin-bottom: 40rpx;
}

/* 我的车库大卡片 - 7:5 比例 */
.menu-card.garage-card {
  width: 100%;
  aspect-ratio: 7 / 5;
  background: linear-gradient(135deg, #0984e3 0%, #74b9ff 100%);
  border-radius: 24rpx;
  padding: 40rpx 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 30rpx rgba(9, 132, 227, 0.3);
  margin-bottom: 24rpx;
  position: relative;
  overflow: hidden;
  box-sizing: border-box;
}

.garage-icon {
  width: 120rpx;
  height: 120rpx;
  border-radius: 28rpx;
  background: #86B8F2;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56rpx;
  margin-bottom: 16rpx;
}

.garage-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #ffffff;
}

.garage-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-top: 8rpx;
}

/* 两个功能卡片横排 */
.func-row {
  display: flex;
  justify-content: space-between;
  gap: 5%;
}

.func-row .func-card {
  flex: 1;
  background: #ffffff;
  border-radius: 20rpx;
  padding: 40rpx 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.func-row .func-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-bottom: 12rpx;
  color: #ffffff;
}

.func-row .func-card:first-child .func-icon {
  background: #3CC6A0;
}

.func-row .func-card:last-child .func-icon {
  background: #8B5CE6;
}

.func-row .func-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #1a1a1a;
}

.func-row .func-desc {
  font-size: 24rpx;
  color: #666666;
  margin-top: 8rpx;
}

/* 快捷操作 */
.quick-actions {
  margin-top: 16rpx;
}

.action-list {
  background: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.action-item {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.action-item:last-child {
  border-bottom: none;
}

.action-icon {
  font-size: 32rpx;
  width: 56rpx;
  text-align: center;
}

.action-text {
  flex: 1;
  font-size: 28rpx;
  color: #2d3436;
  margin-left: 16rpx;
}

.action-arrow {
  font-size: 32rpx;
  color: #b2bec3;
}