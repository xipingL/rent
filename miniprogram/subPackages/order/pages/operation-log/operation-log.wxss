/* pages/operation-log/operation-log.wxss */
.container {
  width: 100%;
  min-height: 100vh;
  background: #f8f9fa;
}

.header {
  width: 100%;
  background: linear-gradient(135deg, #0984e3 0%, #74b9ff 100%);
  padding: 32rpx 24rpx;
  color: #ffffff;
  display: flex;
  align-items: center;
  box-sizing: border-box;
}

.header-left {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.back-btn {
  width: 72rpx;
  height: 72rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
}

.header-title {
  font-size: 40rpx;
  font-weight: 700;
}

/* 搜索筛选栏 */
.search-bar {
  background: #ffffff;
  padding: 20rpx 24rpx;
  border-bottom: 2rpx solid #f0f0f0;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.search-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.filter-picker {
  flex: 0 0 auto;
  min-width: 140rpx;
}

.picker-value {
  background: #f8f9fa;
  border: 2rpx solid #dfe6e9;
  border-radius: 20rpx;
  padding: 14rpx 16rpx;
  font-size: 24rpx;
  color: #2d3436;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.search-input-wrapper {
  flex: 1;
  display: flex;
  align-items: center;
  background: #f8f9fa;
  border-radius: 20rpx;
  padding: 0 16rpx;
  gap: 10rpx;
}

.search-icon {
  color: #b2bec3;
  font-size: 26rpx;
}

.search-input {
  flex: 1;
  padding: 14rpx 0;
  border: none;
  background: transparent;
  font-size: 26rpx;
  color: #2d3436;
  outline: none;
}

.search-input::placeholder {
  color: #b2bec3;
}

.search-btn {
  width: 120rpx;
  height: 64rpx;
  background: rgba(255, 255, 255, 0.95);
  border: none;
  border-radius: 24rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: #0984e3;
  display: flex;
  align-items: center;
  justify-content: center;
}

.search-btn::after {
  border: none;
}

.date-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.date-picker {
  flex: 1;
}

.date-input {
  background: #f8f9fa;
  border: 2rpx solid #dfe6e9;
  border-radius: 16rpx;
  padding: 14rpx 16rpx;
  font-size: 24rpx;
  color: #2d3436;
  text-align: center;
}

.date-separator {
  font-size: 24rpx;
  color: #b2bec3;
  flex: 0 0 auto;
}

.content {
  padding: 24rpx;
  height: calc(100vh - 300rpx);
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  opacity: 0.4;
}

.empty-text {
  margin-top: 32rpx;
  font-size: 32rpx;
  color: #b2bec3;
  font-weight: 600;
}

/* 日志列表 */
.log-list {
  padding: 0 8rpx;
}

.log-item {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.log-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.log-action {
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: #ffffff;
}

.log-action.action-create {
  background: #37B794;
}

.log-action.action-update {
  background: #0984e3;
}

.log-action.action-delete {
  background: #e74c3c;
}

.log-action.action-rent {
  background: #00d4aa;
}

.log-action.action-renew {
  background: #fdcb6e;
}

.log-action.action-settle {
  background: #6c5ce7;
}

.log-time {
  font-size: 24rpx;
  color: #636e72;
}

.log-detail {
  margin-bottom: 12rpx;
}

.log-remark {
  font-size: 28rpx;
  color: #2d3436;
  line-height: 1.5;
}

.log-meta {
  display: flex;
  justify-content: space-between;
  padding-top: 12rpx;
  border-top: 1rpx solid #f1f2f6;
}

.log-collection {
  font-size: 22rpx;
  color: #b2bec3;
  background: #f1f2f6;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
}

.log-id {
  font-size: 22rpx;
  color: #b2bec3;
}