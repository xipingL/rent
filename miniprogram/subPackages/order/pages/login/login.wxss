/* pages/login/login.wxss */
.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #00D4AA 0%, #00B894 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}

.login-content {
  text-align: center;
  color: #fff;
}

.logo {
  font-size: 160rpx;
  margin-bottom: 32rpx;
}

.title {
  font-size: 48rpx;
  font-weight: 700;
  margin-bottom: 16rpx;
}

.subtitle {
  font-size: 28rpx;
  opacity: 0.9;
  margin-bottom: 80rpx;
}

.login-btn {
  width: 560rpx;
  height: 96rpx;
  background: #fff;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 16rpx 40rpx rgba(0, 0, 0, 0.15);
}

.login-btn::after {
  border: none;
}

.btn-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #00D4AA;
}
