<!--pages/rental/rental.wxml-->
<view class="container">
  <view class="header">
    <view class="header-left">
      <view class="back-btn" bindtap="goBack">←</view>
      <view class="header-title">租聘车辆</view>
    </view>
  </view>

  <view class="loading-view" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>
  <scroll-view class="content" scroll-y wx:else>
    <view class="vehicle-card" wx:if="{{vehicle}}">
      <view class="vehicle-thumb">🛵</view>
      <view class="vehicle-info">
        <view class="vehicle-name">{{vehicle.name}}</view>
        <view class="vehicle-detail">{{vehicle.plateNo}} · {{vehicle.color}} · {{vehicle.battery}}</view>
        <text class="vehicle-status">空闲车辆</text>
      </view>
    </view>

    <view class="form-section">
      <view class="form-title">租车人信息</view>

      <view class="form-group">
        <text class="form-label">姓名</text>
        <input type="text" class="form-input" placeholder="请输入租车人姓名" bindinput="onNameInput" value="{{name}}"></input>
      </view>

      <view class="form-group">
        <text class="form-label">手机号码</text>
        <input type="tel" class="form-input" placeholder="请输入手机号码" bindinput="onPhoneInput" value="{{phone}}" maxlength="11"></input>
      </view>

      <view class="form-group">
        <text class="form-label">身份证照片</text>
        <view class="id-photos">
          <view class="id-photo-item {{idCardFront ? 'has-photo' : ''}}" bindtap="chooseIdCardFront">
            <image wx:if="{{idCardFront}}" class="id-photo-img" src="{{idCardFront}}" mode="aspectFill"></image>
            <block wx:else>
              <text class="id-photo-icon">📷</text>
              <text class="id-photo-text">身份证正面</text>
            </block>
          </view>
          <view class="id-photo-item {{idCardBack ? 'has-photo' : ''}}" bindtap="chooseIdCardBack">
            <image wx:if="{{idCardBack}}" class="id-photo-img" src="{{idCardBack}}" mode="aspectFill"></image>
            <block wx:else>
              <text class="id-photo-icon">📷</text>
              <text class="id-photo-text">身份证反面</text>
            </block>
          </view>
        </view>
      </view>
    </view>

    <view class="form-section">
      <view class="form-title">车辆照片</view>
      <view class="photos-grid">
        <block wx:for="{{vehiclePhotos}}" wx:key="*this">
          <view class="photo-item">
            <image class="photo-img" src="{{item}}" mode="aspectFill"></image>
            <view class="photo-delete" bindtap="deleteVehiclePhoto" data-index="{{index}}">×</view>
          </view>
        </block>
        <view class="photo-item add" bindtap="chooseVehiclePhoto" wx:if="{{vehiclePhotos.length < 9}}">+</view>
      </view>
      <view class="photo-tip">若您未上传车辆照片，系统将使用车辆档案中的默认图片作为订单中的车辆照片。</view>
    </view>

    <view class="form-section">
      <view class="form-title">租聘信息</view>

      <view class="form-group">
        <text class="form-label">起租时间</text>
        <view class="picker-input" bindtap="showDateTimePicker">{{startTime || '请选择起租时间'}}</view>
        <van-popup show="{{showPicker}}" round position="bottom" bind:close="closeDateTimePicker">
          <van-datetime-picker
            type="datetime"
            value="{{startTimeStamp}}"
            bind:confirm="onDateTimeConfirm"
            bind:cancel="closeDateTimePicker"
            min-date="{{minDate}}"
          />
        </van-popup>
      </view>

      <view class="form-group">
        <text class="form-label">租聘时长</text>
        <view class="duration-options">
          <view class="duration-btn {{duration === 1 ? 'active' : ''}}" bindtap="selectDuration" data-days="1">1天</view>
          <view class="duration-btn {{duration === 3 ? 'active' : ''}}" bindtap="selectDuration" data-days="3">3天</view>
          <view class="duration-btn {{duration === 7 ? 'active' : ''}}" bindtap="selectDuration" data-days="7">7天</view>
          <view class="duration-btn {{duration === 15 ? 'active' : ''}}" bindtap="selectDuration" data-days="15">15天</view>
          <view class="duration-btn {{duration === 30 ? 'active' : ''}}" bindtap="selectDuration" data-days="30">30天</view>
          <view class="duration-btn {{duration === -1 ? 'active' : ''}}" bindtap="selectDuration" data-days="-1">自定义</view>
        </view>
      </view>

      <view class="form-group" wx:if="{{duration === -1}}">
        <view class="picker-input" bindtap="showExpireDatePicker">{{customDurationText || '请选择租聘时长'}}</view>
        <van-popup show="{{showExpirePicker}}" round position="bottom" bind:close="closeExpireDatePicker">
          <van-picker
            id="durationPicker"
            show-toolbar
            title="租聘时长"
            columns="{{durationColumns}}"
            bind:change="onDurationChange"
            bind:confirm="onDurationConfirm"
            bind:cancel="closeExpireDatePicker"
          />
        </van-popup>
      </view>

      <view class="form-group">
        <text class="form-label">到期时间</text>
        <view class="expire-time">
          <text class="expire-label">预计归还时间</text>
          <text class="expire-value">{{expireTime}}</text>
        </view>
      </view>
    </view>

    <view class="submit-section">
      <button class="submit-btn" bindtap="confirmRental">确认租聘</button>
    </view>
  </scroll-view>
</view>
