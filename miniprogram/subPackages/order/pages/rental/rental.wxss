/* pages/rental/rental.wxss */
.container {
  min-height: 100vh;
  background: #f8f9fa;
  display: flex;
  flex-direction: column;
}

.header {
  width: 100%;
  background: linear-gradient(135deg, #00d4aa 0%, #00b894 100%);
  padding: 32rpx 48rpx;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-sizing: border-box;
}

.header-left {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.back-btn {
  width: 72rpx;
  height: 72rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
}

.header-title {
  font-size: 36rpx;
  font-weight: 700;
}

.loading-view {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #636e72;
  font-size: 28rpx;
}

.content {
  padding: 0;
  height: calc(100vh - 160rpx);
  flex: 1;
}

.vehicle-card {
  background: #ffffff;
  padding: 32rpx 40rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.vehicle-thumb {
  width: 120rpx;
  height: 120rpx;
  background: linear-gradient(135deg, #dfe6e9 0%, #b2bec3 100%);
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 60rpx;
}

.vehicle-info {
  flex: 1;
}

.vehicle-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #2d3436;
}

.vehicle-detail {
  font-size: 24rpx;
  color: #636e72;
  margin-top: 8rpx;
}

.vehicle-status {
  font-size: 22rpx;
  color: #00b894;
  background: #e8f8f5;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  margin-top: 8rpx;
  display: inline-block;
}

.form-section {
  background: #ffffff;
  padding: 40rpx;
  margin-top: 24rpx;
}

.form-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #2d3436;
  margin-bottom: 32rpx;
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid #f1f2f6;
}

.form-group {
  margin-bottom: 32rpx;
}

.form-label {
  font-size: 24rpx;
  color: #636e72;
  margin-bottom: 16rpx;
  display: block;
}

.form-input {
  width: 100%;
  height: 88rpx;
  padding: 0 32rpx;
  border: 2rpx solid #dfe6e9;
  border-radius: 20rpx;
  font-size: 28rpx;
  color: #2d3436;
  background: #f8f9fa;
  box-sizing: border-box;
  display: flex;
  align-items: center;
}

.picker-input {
  width: 100%;
  height: 88rpx;
  padding: 0 32rpx;
  border: 2rpx solid #dfe6e9;
  border-radius: 20rpx;
  font-size: 28rpx;
  color: #2d3436;
  background: #f8f9fa;
  box-sizing: border-box;
  display: flex;
  align-items: center;
}

.id-photos {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24rpx;
}

.id-photo-item {
  aspect-ratio: 1.4;
  background: #f1f2f6;
  border: 4rpx dashed #dfe6e9;
  border-radius: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
}

.id-photo-item.has-photo {
  background: linear-gradient(135deg, #dfe6e9 0%, #b2bec3 100%);
  border: none;
}

.id-photo-img {
  width: 100%;
  height: 100%;
}

.id-photo-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.id-photo-text {
  font-size: 24rpx;
  color: #636e72;
}

.photos-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.photo-item {
  aspect-ratio: 1;
  background: #f1f2f6;
  border: 4rpx dashed #dfe6e9;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  position: relative;
  overflow: hidden;
}

.photo-img {
  width: 100%;
  height: 100%;
}

.photo-delete {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 40rpx;
  height: 40rpx;
  background: rgba(231, 76, 60, 0.9);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 28rpx;
  line-height: 1;
}

.photo-item.add {
  font-size: 40rpx;
  color: #b2bec3;
}

.photo-tip {
  font-size: 22rpx;
  color: #b2bec3;
  margin-top: 24rpx;
  text-align: center;
}

.duration-picker {
  background: #fff;
}

.picker-header {
  display: flex;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #eee;
  font-size: 28rpx;
}

.picker-header text:first-child {
  color: #969799;
}

.picker-header text:last-child {
  color: #576b95;
}

.duration-picker-view {
  height: 400rpx;
  display: flex;
  align-items: center;
}

.picker-col {
  flex: 1;
  text-align: center;
}

.duration-options {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}

.duration-btn {
  padding: 20rpx 32rpx;
  background: #f1f2f6;
  border-radius: 20rpx;
  font-size: 26rpx;
  color: #636e72;
}

.duration-btn.active {
  background: linear-gradient(135deg, #00d4aa 0%, #00b894 100%);
  color: #ffffff;
}

.expire-time {
  background: #e8f8f5;
  border-radius: 24rpx;
  padding: 32rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.expire-label {
  font-size: 26rpx;
  color: #636e72;
}

.expire-value {
  font-size: 32rpx;
  font-weight: 600;
  color: #00b894;
}

.submit-section {
  padding: 40rpx;
  background: #ffffff;
  margin-top: 24rpx;
}

.submit-btn {
  width: 100%;
  padding: 32rpx;
  background: linear-gradient(135deg, #00d4aa 0%, #00b894 100%);
  color: #ffffff;
  border: none;
  border-radius: 24rpx;
  font-size: 32rpx;
  font-weight: 600;
}
