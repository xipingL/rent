/* pages/garage-edit/garage-edit.wxss */
.container {min-height: 100vh;background: #f8f9fa;display: flex;flex-direction: column;}
.header {width: 100%;background: linear-gradient(135deg, #0984e3 0%, #74b9ff 100%);padding: 32rpx 48rpx;color: #fff;display: flex;align-items: center;box-sizing: border-box;}
.header-left {display: flex;align-items: center;gap: 24rpx;}
.back-btn {width: 72rpx;height: 72rpx;background: rgba(255,255,255,0.2);border-radius: 50%;display: flex;align-items: center;justify-content: center;font-size: 36rpx;}
.header-title {font-size: 36rpx;font-weight: 700;}
.loading-view {flex: 1;display: flex;align-items: center;justify-content: center;color: #636e72;font-size: 28rpx;}
.content {padding: 0;flex: 1;height: calc(100vh - 120rpx);}
.cover-section {width: 100%;height: 400rpx;background: linear-gradient(135deg, #dfe6e9 0%, #b2bec3 100%);display: flex;align-items: center;justify-content: center;position: relative;}
.cover-emoji {font-size: 160rpx;}
.cover-img {width: 100%;height: 100%;}
.edit-cover-btn {position: absolute;bottom: 32rpx;right: 32rpx;background: rgba(0,0,0,0.5);color: #fff;padding: 16rpx 32rpx;border-radius: 40rpx;font-size: 24rpx;}
.form-section {background: #fff;padding: 40rpx;}
.form-title {font-size: 28rpx;font-weight: 600;color: #2d3436;margin-bottom: 32rpx;padding-bottom: 16rpx;border-bottom: 2rpx solid #f1f2f6;}
.form-row {display: flex;gap: 24rpx;}
.form-group {margin-bottom: 32rpx;flex: 1;}
.form-label {font-size: 24rpx;color: #636e72;margin-bottom: 12rpx;display: block;}
.form-input {width: 100%;height: 88rpx;padding: 0 32rpx;border: 2rpx solid #dfe6e9;border-radius: 20rpx;font-size: 28rpx;color: #2d3436;background: #f8f9fa;box-sizing: border-box;display: flex;align-items: center;}
.photos-section {background: #fff;padding: 40rpx;margin-top: 24rpx;}
.photos-grid {display: grid;grid-template-columns: repeat(3, 1fr);gap: 16rpx;}
.photo-item {aspect-ratio: 1;background: linear-gradient(135deg, #dfe6e9 0%, #b2bec3 100%);border-radius: 24rpx;display: flex;align-items: center;justify-content: center;font-size: 56rpx;position: relative;overflow: hidden;}
.photo-item image {width: 100%;height: 100%;}
.photo-delete {position: absolute;top: 8rpx;right: 8rpx;width: 40rpx;height: 40rpx;background: rgba(231,76,60,0.9);border-radius: 50%;display: flex;align-items: center;justify-content: center;color: #fff;font-size: 24rpx;}
.photo-item.add {background: #f1f2f6;border: 4rpx dashed #dfe6e9;font-size: 48rpx;color: #b2bec3;}
.submit-section {padding: 40rpx;background: #fff;margin-top: 24rpx;}
.submit-btn {width: 100%;padding: 32rpx;background: linear-gradient(135deg, #0984e3 0%, #74b9ff 100%);color: #fff;border: none;border-radius: 24rpx;font-size: 32rpx;font-weight: 600;}