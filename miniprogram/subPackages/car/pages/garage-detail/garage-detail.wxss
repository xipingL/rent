/* pages/garage-detail/garage-detail.wxss */
.container {
  min-height: 100vh;
  background: #f8f9fa;
  display: flex;
  flex-direction: column;
}

.header {
  width: 100%;
  background: linear-gradient(135deg, #0984e3 0%, #74b9ff 100%);
  padding: 32rpx 48rpx;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-sizing: border-box;
}

.header-left {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.back-btn {
  width: 72rpx;
  height: 72rpx;
  background: rgba(255,255,255,0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
}

.header-title {
  font-size: 36rpx;
  font-weight: 700;
}

.header-actions {
  display: flex;
  gap: 16rpx;
}

.action-icon {
  width: 72rpx;
  height: 72rpx;
  background: rgba(255,255,255,0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
}

.loading-view {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #636e72;
  font-size: 28rpx;
}

.content {
  padding: 0;
  flex: 1;
  height: calc(100vh - 160rpx);
}

.cover-section {
  width: 100%;
  height: 400rpx;
  background: linear-gradient(135deg, #dfe6e9 0%, #b2bec3 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.cover-img {
  width: 100%;
  height: 100%;
}

.cover-emoji {
  font-size: 160rpx;
}

.vehicle-status {
  position: absolute;
  top: 32rpx;
  right: 32rpx;
  padding: 16rpx 32rpx;
  border-radius: 40rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: #fff;
}

.status-0 {background: #00b894;}
.status-1 {background: #fdcb6e; color: #d35400;}
.status-2 {background: #e17055;}

.info-section {
  background: #fff;
  padding: 40rpx;
}

.info-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}

.vehicle-name {
  font-size: 40rpx;
  font-weight: 700;
  color: #2d3436;
}

.vehicle-brand {
  font-size: 24rpx;
  color: #636e72;
  background: #f1f2f6;
  padding: 8rpx 20rpx;
  border-radius: 8rpx;
  margin-top: 8rpx;
  display: inline-block;
}

.info-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 32rpx;
}

.info-item {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.info-label {
  font-size: 22rpx;
  color: #b2bec3;
}

.info-value {
  font-size: 28rpx;
  color: #2d3436;
  font-weight: 500;
}

.info-value.license {
  background: #dfe6e9;
  padding: 12rpx 20rpx;
  border-radius: 12rpx;
  display: inline-block;
}

.info-note {
  margin-top: 32rpx;
  padding-top: 32rpx;
  border-top: 2rpx solid #f1f2f6;
}

.note-label {
  font-size: 22rpx;
  color: #b2bec3;
  margin-bottom: 8rpx;
  display: block;
}

.photos-section {
  background: #fff;
  padding: 40rpx;
  margin-top: 24rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #2d3436;
  margin-bottom: 24rpx;
}

.photos-grid {
  display: flex;
  gap: 16rpx;
  overflow-x: auto;
  padding-bottom: 16rpx;
}

.photo-item {
  width: 300rpx;
  height: 300rpx;
  flex-shrink: 0;
  background: linear-gradient(135deg, #dfe6e9 0%, #b2bec3 100%);
  border-radius: 24rpx;
  overflow: hidden;
}

.photo-item image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.rental-section {
  background: #fff;
  padding: 40rpx;
  margin-top: 24rpx;
}

.rental-card {
  background: #f8f9fa;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.rental-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.rental-user {
  font-size: 30rpx;
  font-weight: 600;
  color: #2d3436;
}

.rental-phone {
  font-size: 26rpx;
  color: #636e72;
}

.rental-dates {
  display: flex;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.rental-dates view {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.date-label {
  font-size: 22rpx;
  color: #b2bec3;
}

.date-value {
  font-size: 26rpx;
  color: #2d3436;
}

.rental-duration {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding-top: 24rpx;
  border-top: 2rpx solid #dfe6e9;
}

.duration-label {
  font-size: 22rpx;
  color: #b2bec3;
}

.duration-value {
  font-size: 26rpx;
  color: #2d3436;
  font-weight: 600;
}

.empty-tip {
  text-align: center;
  color: #b2bec3;
  font-size: 28rpx;
  padding: 100rpx 40rpx;
}